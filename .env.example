# =============================================================================
# Local: copy to `.env.local` and fill in values.
# Vercel: Project → Settings → Environment Variables — create the SAME keys below
#         (Production + Preview at minimum; mark secrets as Sensitive).
#         Redeploy after adding or changing variables.
# =============================================================================
#
# Vercel checklist (names only — you paste values in the dashboard):
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#   CALCOM_OAUTH_CLIENT_ID
#   CALCOM_OAUTH_CLIENT_SECRET
#   CALCOM_WEBHOOK_SECRET
#   TOKEN_ENCRYPTION_KEY
#   RESEND_API_KEY                     ← optional; enables in-app email sending
#   RESEND_FROM_EMAIL                  ← optional; verified Resend sender address
#   NEXT_PUBLIC_SITE_URL               ← e.g. https://your-app.vercel.app (recommended in prod)
#
# =============================================================================

# Public (safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cal.com — single-host mode (current). Every signed-in user shares this
# Cal.com account; the booking URL below is shown on their dashboard.
# Get an API key at https://app.cal.com/settings/developer/api-keys.
CALCOM_API_KEY=cal_live_your_personal_api_key
CALCOM_BOOKING_URL=https://cal.com/your-username/your-event-slug

# Multi-host alternatives (not required when CALCOM_API_KEY is set):
#   1. Per-host pasted API keys — hosts paste their own key in
#      Settings → Cal.com (stored encrypted in host_calcom_credentials).
#   2. OAuth (Cal.com Platform / Organization) — requires a paid Platform
#      plan; hosts click "Connect with Cal.com OAuth" in Settings.
CALCOM_OAUTH_CLIENT_ID=your_calcom_oauth_client_id
CALCOM_OAUTH_CLIENT_SECRET=your_calcom_oauth_client_secret

# Cal.com webhook HMAC secret (auto-registered via API on event type selection,
# also configurable in Cal.com → Settings → Developer → Webhooks)
CALCOM_WEBHOOK_SECRET=change_me_to_a_random_secret

# AES-256-GCM key for encrypting Cal.com tokens at rest (min 32 chars)
TOKEN_ENCRYPTION_KEY=change_me_to_a_32_char_random_string!

# Resend — transactional email (guest invites, prep, follow-ups). When unset,
# the in-app "Send email" composer is disabled and hosts fall back to Gmail.
# Get a key at https://resend.com/api-keys. RESEND_FROM_EMAIL must use a
# domain you've verified in Resend (defaults to the resend.dev sandbox).
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=The Reunion Projects <hello@your-verified-domain.com>

# Canonical site URL for auth redirects in production (optional locally)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
