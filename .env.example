# =============================================================================
# Local: copy to `.env.local` and fill in values.
# Vercel: Project → Settings → Environment Variables — create the SAME keys below
#         (Production + Preview at minimum; mark secrets as Sensitive).
#         Redeploy after adding or changing variables.
# =============================================================================
#
# Vercel checklist (names only — you paste values in the dashboard):
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY          ← required for /auth/callback + Google token storage
#   OAUTH_TOKEN_ENCRYPTION_KEY         ← long random secret; same across envs that share users
#   GOOGLE_CLIENT_ID
#   GOOGLE_CLIENT_SECRET
#   NEXT_PUBLIC_SITE_URL               ← e.g. https://your-app.vercel.app (recommended in prod)
#
# =============================================================================

# Public (safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AES-256-GCM for Google refresh/access tokens at rest (e.g. openssl rand -hex 32)
OAUTH_TOKEN_ENCRYPTION_KEY=change_me_to_a_long_random_secret_at_least_32_chars

# Canonical site URL for OAuth redirectTo in production (optional locally)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Cloud OAuth (Web client) — same as Supabase Auth → Providers → Google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
