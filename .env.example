# Public (safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Used for AES-256-GCM encryption of Google refresh/access tokens at rest (pick a long random secret)
OAUTH_TOKEN_ENCRYPTION_KEY=change_me_to_a_long_random_secret_at_least_32_chars

# Optional: defaults to request origin in dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Cloud OAuth (Web client) — same Client ID/Secret as configured in Supabase Auth → Google provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
