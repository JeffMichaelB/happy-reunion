# =============================================================================
# Local: copy to `.env.local` and fill in values.
# Vercel: Project → Settings → Environment Variables — create the SAME keys below
#         (Production + Preview at minimum; mark secrets as Sensitive).
#         Redeploy after adding or changing variables.
# =============================================================================
#
# Vercel checklist (names only — you paste values in the dashboard):
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#   TOKEN_ENCRYPTION_KEY
#   RESEND_API_KEY                     ← optional; enables in-app email sending
#   RESEND_FROM_EMAIL                  ← optional; verified Resend sender address
#   NEXT_PUBLIC_SITE_URL               ← e.g. https://your-app.vercel.app (recommended in prod)
#
# =============================================================================

# Public (safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cal.com — API-key only. Hosts connect by pasting their own personal API key
# in onboarding / Settings (stored encrypted in host_calcom_credentials). Each
# host's webhook is registered with its own per-host secret, so no global
# webhook secret is needed. OAuth is retired (Cal.com closed new Platform/OAuth
# signups Dec 15 2025).
#
# Optional shared/dev mode: setting CALCOM_API_KEY makes every signed-in host
# share one Cal.com account using the booking URL below. Leave both unset for
# the standard per-host flow.
# CALCOM_API_KEY=cal_live_your_personal_api_key
# CALCOM_BOOKING_URL=https://cal.com/your-username/your-event-slug

# DEPRECATED / transitional: only read by hosts whose webhook was registered
# before per-host secrets shipped. New registrations generate their own secret.
# Safe to remove once every host has re-selected their event type.
# CALCOM_WEBHOOK_SECRET=change_me_to_a_random_secret

# AES-256-GCM key for encrypting Cal.com API keys + per-host webhook secrets at
# rest (min 32 chars)
TOKEN_ENCRYPTION_KEY=change_me_to_a_32_char_random_string!

# Resend — transactional email (guest invites, prep, follow-ups). When unset,
# the in-app "Send email" composer is disabled and hosts fall back to Gmail.
# Get a key at https://resend.com/api-keys. RESEND_FROM_EMAIL must use a
# domain you've verified in Resend (defaults to the resend.dev sandbox).
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=The Reunion Projects <hello@your-verified-domain.com>

# Canonical site URL for auth redirects in production (optional locally)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
